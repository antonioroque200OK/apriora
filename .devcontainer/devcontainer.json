{
  "name": "Apriora",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:1-24-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },
  "onCreateCommand": "corepack enable && corepack use pnpm@10 && pnpm install",
  "postCreateCommand": "pnpm --filter @apriora/web run build || true",
  "customizations": {
    "vscode": {
      "extensions": [
        "biomejs.biome",
        "bradlc.vscode-tailwindcss",
        "ms-vscode.vscode-typescript-next",
        "prisma.prisma",
        "expo.vscode-expo-tools",
        "ms-azuretools.vscode-docker",
        "GitHub.vscode-pull-request-github"
      ],
      "settings": {
        "editor.defaultFormatter": "biomejs.biome",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.organizeImports.biome": "explicit",
          "quickfix.biome": "explicit"
        },
        "[json]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[typescript]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[typescriptreact]": {
          "editor.defaultFormatter": "biomejs.biome"
        }
      }
    }
  },
  "forwardPorts": [3000, 3001, 5432, 8081],
  "portsAttributes": {
    "3000": { "label": "web (Next.js)" },
    "3001": { "label": "api (NestJS)" },
    "5432": { "label": "postgres" },
    "8081": { "label": "mobile (Expo)" }
  }
}
